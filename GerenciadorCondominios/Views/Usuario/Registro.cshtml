@model GerenciadorCondominios.ViewModels.RegistroViewModel
@{
    Layout = null;
    ViewData["Title"] = "Cadastro de moradores";
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-widht" />
    <title>Novo morador</title>

    <environment include="Development">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.css">
        <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
        <link href="~/css/site.css" rel="stylesheet" />
    </environment>

    <environment exclude="Development">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css">
        <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
        <link href="~/css/site.min.css" rel="stylesheet" />
    </environment>
</head>
<body class="corpo">

    <div class="registroform">
        <div class="center-align">
            <h4><i class="large material-icons">account_circle</i></h4>
            <h5>Novo morador</h5>

            <div>
                <form asp-action="Registro" enctype="multipart/form-data">
                    <div class="campos">
                        <div class="red-text text-darken-4" asp-validation-summary="ModelOnly"></div>

                        <div class="row">
                            <div class="input-field col s12">
                                <input asp-for="Nome" class="validate" id="Nome" />
                                <label asp-for="Nome" id="Nome"></label>
                                <span class="red-text text-darken-4" asp-validation-for="Nome"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="input-field col s12">
                                <input asp-for="Cpf" class="validate" id="Cpf" />
                                <label asp-for="Cpf" id="Cpf"></label>
                                <span class="red-text text-darken-4" asp-validation-for="Cpf"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="input-field col s12">
                                <input asp-for="Telefone" class="validate" id="Telefone" />
                                <label asp-for="Telefone" id="Telefone"></label>
                                <span class="red-text text-darken-4" asp-validation-for="Telefone"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="file-field input-field col s12">
                                <div class="btn-small">
                                    <span>Selecione sua foto</span>
                                    <input asp-for="Foto" type="file" class="validate" id="foto" />
                                </div>

                                <div class="file-path-wrapper">
                                    <input class="file-path validate" type="text" />
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="input-field col s12">
                                <input asp-for="Email" class="validate" type="email" id="Email" />
                                <label asp-for="Email" id="Email"></label>
                                <span class="red-text text-darken-4" asp-validation-for="Email"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="input-field col s12">
                                <input asp-for="Senha" class="validate" type="password" id="Senha" />
                                <label asp-for="Senha" id="Senha"></label>
                                <span class="red-text text-darken-4" asp-validation-for="Senha"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="input-field col s12">
                                <input asp-for="SenhaConfirmada" class="validate" type="password" id="SenhaConfirmada" />
                                <label asp-for="SenhaConfirmada" id="SenhaConfirmada"></label>
                                <span class="red-text text-darken-4" asp-validation-for="SenhaConfirmada"></span>
                            </div>
                        </div>

                    </div>

                    <div class="botoes">
                        <button type="submit" class="waves-effect waves-light btn-small green text-darken-4">Registrar</button>&emsp;
                        <a asp-controller="Usuario" asp-action="Login">Já possuo uma conta</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <environment include="Development">
        <script src="https://code.jquery.com/jquery-3.6.0.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.js"></script>
        <script src="~/js/IniciarMascaras.js"></script>
    </environment>

    <environment exclude="Development">
        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.maskedinput/1.4.1/jquery.maskedinput.min.js"></script>
        <script src="~/js/IniciarMascaras.js"></script>
    </environment>
</body>
</html>