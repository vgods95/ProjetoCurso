@model GerenciadorCondominios.BLL.Models.Funcao

@{
    ViewData["Title"] = "Alterar função " + Model.Name;
}

<div class="formulario">
    <div class="collection with-header">
        <form asp-action="Edit">
            <div class="collection-header blue darken-3">
                <h6 class="white-text">Alterar função @Model.Name</h6>
            </div>

            <div class="collection-item">
                <div asp-validation-summary="ModelOnly" class="red-text text-darken-4"></div>
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="input-field col s12">
                        <input asp-for="Name" class="validate" id="name" />
                        <label asp-for="Name" id="name">Nome</label>
                        <span class="red-text text-darken-4" asp-validation-for="Name"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="input-field col s12">
                        <input asp-for="Descricao" class="validate" id="descricao" />
                        <label asp-for="Descricao" id="descricao">Descrição</label>
                        <span class="red-text text-darken-4" asp-validation-for="Descricao"></span>
                    </div>
                </div>

                <div class="collection-item">
                    <button type="submit" class="btn-small blue darken-3">Salvar</button> &emsp;
                    <a asp-action="Index" asp-controller="Funcao">Voltar</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts{
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

